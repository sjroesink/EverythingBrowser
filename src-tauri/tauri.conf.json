{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "EverythingBrowser",
  "version": "0.1.0",
  "identifier": "com.everythingbrowser.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1460",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EverythingBrowser",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "cli": {
      "description": "A file transfer client for SFTP and Backblaze B2",
      "args": [
        {
          "name": "connect",
          "short": "c",
          "takesValue": true,
          "description": "Open a saved connection by name or ID"
        }
      ]
    }
  }
}
